# Copy to .env.local and fill in your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Max in-flight Gemini API calls (default 3). Lower to 1 or 2 if you see 429 errors.
GEMINI_MAX_CONCURRENT=3

# Retries on transient 429/503 (default 3)
GEMINI_MAX_RETRIES=3

# Retries when agent returns invalid JSON (default 3)
GEMINI_MAX_PARSE_RETRIES=3
